# ── Demo / Local Mode ───────────────────────────────────────────────────────
# Set to "true" to force demo mode (localStorage, no backend required).
# Leave unset or set to "false" to use Netlify Functions + Supabase.
VITE_DEMO_MODE=true

# ── Supabase (Production Mode) ────────────────────────────────────────────────
# Required for full backend persistence.
# Use SUPABASE_URL (not VITE_) for server-side functions.
# Use VITE_SUPABASE_URL (with VITE_) for direct frontend Supabase access if needed.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# ── Live Intake Kill Switch ────────────────────────────────────────────────────
# MUST be explicitly set to "true" to enable automated RSS/API source ingestion.
# Default: false (safe by default).
# Manual and CSV intake are ALWAYS allowed regardless of this setting.
LIVE_INTAKE_ENABLED=false

# ── n8n Webhook Secret (optional) ─────────────────────────────────────────────
# If using n8n to call intake/approve endpoints, set a shared secret.
N8N_WEBHOOK_SECRET=
