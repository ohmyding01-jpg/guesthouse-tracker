# ── Demo / Local Mode ───────────────────────────────────────────────────────
# Set to "true" to force demo mode (localStorage, no backend required).
# Leave unset or set to "false" to use Netlify Functions + Supabase.
# NOTE: Do NOT set this in netlify.toml [build.environment] for production deploys.
VITE_DEMO_MODE=true

# ── Supabase (Production Mode) ────────────────────────────────────────────────
# Required for full backend persistence.
# Use SUPABASE_URL (not VITE_) for server-side functions.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# ── Live Intake Kill Switch ────────────────────────────────────────────────────
# MUST be explicitly set to "true" to enable automated RSS/API source ingestion.
# Default: false (safe by default).
# Manual and CSV intake are ALWAYS allowed regardless of this setting.
LIVE_INTAKE_ENABLED=false

# ── Discovery Auth ─────────────────────────────────────────────────────────────
# Secret token required to call POST /discover.
# Set this in both Netlify (server env) and in n8n (as DISCOVERY_SECRET env var).
# Callers must send either:
#   Authorization: Bearer <DISCOVERY_SECRET>
# OR
#   X-Discovery-Secret: <DISCOVERY_SECRET>
# If unset, /discover is closed (all requests return 401) in live mode.
# Demo mode skips the secret check (discovery is a no-op in demo mode).
DISCOVERY_SECRET=your-secret-here

# ── Per-Run Safety Cap ─────────────────────────────────────────────────────────
# Maximum number of job records to process per scheduled ingestion run.
# Prevents runaway ingestion from a suddenly noisy source.
# Default: 50 (conservative). Set higher only after verifying source quality.
MAX_RECORDS_PER_RUN=50

# ── Greenhouse Job Board Discovery ────────────────────────────────────────────
# Comma-separated list of Greenhouse board tokens (company slugs) to discover jobs from.
# Example: telstra,anz,atlassian,servicenow
# Find the board token in the Greenhouse public board URL: https://boards.greenhouse.io/{boardToken}
# Auth: None required — these are public job boards.
GREENHOUSE_BOARDS=

# ── Lever Job Postings Discovery ──────────────────────────────────────────────
# Comma-separated list of Lever company slugs to discover jobs from.
# Example: atlassian,canva,xero
# Find the slug in the Lever public URL: https://jobs.lever.co/{siteSlug}
# Auth: None required — public postings API.
LEVER_BOARDS=

# ── USAJobs API ───────────────────────────────────────────────────────────────
# Required to fetch from the USAJobs REST API (US federal government jobs).
# Register at: https://developer.usajobs.gov/
# USAJOBS_USER_AGENT must be the email address used to register the API key.
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=
USAJOBS_KEYWORD=technical project manager

# ── Outbound Webhooks (Zapier / n8n / other) ──────────────────────────────────
# Catch-all webhook destination. Used for all events unless a per-event URL is set.
# Set this to your Zapier Catch Hook URL or any webhook receiver.
WEBHOOK_URL=

# Per-event webhook URL overrides (optional — override the catch-all for specific events).
# Events: new_strong_fit, queue_updated, stale_reminder, weekly_summary, source_failure,
#         ingestion_complete, apply_pack_generated, strong_fit_ready_to_apply,
#         apply_status_changed, discovery_run_complete
WEBHOOK_URL_NEW_STRONG_FIT=
WEBHOOK_URL_QUEUE_UPDATED=
WEBHOOK_URL_STALE_REMINDER=
WEBHOOK_URL_WEEKLY_SUMMARY=
WEBHOOK_URL_SOURCE_FAILURE=
WEBHOOK_URL_INGESTION_COMPLETE=
WEBHOOK_URL_APPLY_PACK_GENERATED=
WEBHOOK_URL_STRONG_FIT_READY_TO_APPLY=
WEBHOOK_URL_APPLY_STATUS_CHANGED=
WEBHOOK_URL_DISCOVERY_RUN_COMPLETE=

# Optional shared secret sent as X-Webhook-Secret header on all outbound webhook calls.
WEBHOOK_SECRET=

# ── n8n Webhook Secret (legacy) ───────────────────────────────────────────────
# If using n8n to call intake/approve endpoints, set a shared secret.
N8N_WEBHOOK_SECRET=
